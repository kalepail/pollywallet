{
  "name": "pollywallet",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "pnpm --filter './bindings/*' build && vite build",
    "preview": "pnpm run build && vite preview",
    "test": "vitest run",
    "test:e2e": "bash scripts/e2e-test.sh",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@cloudflare/kumo": "^1.18.0",
    "@cloudflare/sandbox": "^0.8.7",
    "@cloudflare/vite-plugin": "^1.31.1",
    "@openzeppelin/relayer-plugin-channels": "^0.20.0",
    "@phosphor-icons/react": "^2.1.10",
    "@simplewebauthn/browser": "^13.3.0",
    "@stellar/stellar-sdk": "^15.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-start": "^1.167.16",
    "@tanstack/router-plugin": "^1.167.12",
    "base64url": "^3.0.1",
    "buffer": "^6.0.3",
    "lucide-react": "^1.8.0",
    "multisig-account": "workspace:*",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4",
    "wrangler": "^4.81.0"
  }
}